# wallet-intelligence needs NO API key: it reads Ethereum mainnet through free, keyless
# public JSON-RPC endpoints. This file exists for consistency with the other repos in the
# handbook, and to show where an OPTIONAL key would go.

# Optional. Only used if you later extend the notebook to pull verified ABIs or long
# transaction history from Etherscan. Nothing in this repo requires it; every keyed cell
# is gated and the notebook runs fully without this line.
# ETHERSCAN_API_KEY=your_key_here

# Optional. Override the RPC list if you prefer your own (still keyless / your own node).
# ETH_RPC_URL=https://ethereum-rpc.publicnode.com
